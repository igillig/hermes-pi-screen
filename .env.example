# ─────────────────────────────────────────────────────────────
# parche-ui + orchestrator — full stack config (`docker compose -f stack.yml`)
# ─────────────────────────────────────────────────────────────

# ── UI (parche-ui) ────────────────────────────────────────────
# nginx reverse-proxies /api/* to the Hermes container, so the browser talks
# same-origin and the API key stays server-side. Usually you only set:

# API key injected by nginx into the Authorization header at runtime.
# (Runtime env — NOT inlined by Vite, NOT shipped to the browser.)
# Also reused by the orchestrator container to call Hermes directly.
HERMES_API_KEY=your-api-key-here

# Host port to publish the UI on (container listens on 80).
HOST_PORT=8080

# API base URL baked into the bundle. Defaults to /api (same-origin proxy);
# only change it if you are NOT using the nginx proxy.
# VITE_HERMES_API_URL=/api

# Status updates ({"status": "idle"|"listening"|"thinking"|"talking"}) come
# same-origin by default: nginx proxies /ws-status to the orchestrator
# container over the internal docker network (see nginx.conf), so you normally
# never set this. Only needed if you're bypassing that proxy entirely (e.g.
# pointing the UI at an orchestrator running somewhere else).
# VITE_ORCHESTRATOR_WS_URL=ws://192.168.1.xxx:8765

# ── Orchestrator (voice: Realtime API + Hermes bridge) ───────────────────────
# Branch feature/openai-realtime — see orchestrator/.env.example for the full
# list. These are the ones docker compose actually reads from here.

# Auth for the OpenAI Realtime API (speech-to-speech — replaces the old
# separate Whisper STT + TTS calls entirely).
OPENAI_API_KEY=sk-your-key-here

# REALTIME_MODEL=gpt-realtime
# REALTIME_VOICE=marin

# Audio devices default to the PulseAudio virtual devices docker-entrypoint.sh
# sets up via module-echo-cancel (WebRTC AEC3) — filters Parche's own voice
# out of the mic so barge-in works without an isolated headset. Only override
# if you're not using the MixAmp/asound.conf setup this was built for.
# MIC_DEVICE=echo_cancelled_mic
# SPEAKER_DEVICE=echo_cancelled_speaker

# Fallback if AEC isn't enough on your hardware: mutes the mic entirely while
# Parche talks instead, trading away barge-in for stability.
# MIC_MUTE_WHILE_SPEAKING=false

# Wake word off by default (session starts/stops via the UI's button instead).
# WAKE_WORD_ENABLED=false
# OWW_MODEL_PATH=/app/models/che_parche.onnx
# OWW_THRESHOLD=0.5

# ── Local development (npm run dev) ──────────────────────────
# There is no nginx proxy in `vite dev`, so point straight at Hermes.
# IMPORTANT: Vite inlines VITE_* at BUILD time.
# VITE_HERMES_API_URL=http://192.168.1.xxx:8000
