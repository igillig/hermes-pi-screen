# ─────────────────────────────────────────────────────────────
# parche-ui (HERMES frontend) configuration
#
# IMPORTANT: Vite inlines these VITE_* variables at BUILD TIME.
# They are NOT read at runtime: they must be present when running
# `npm run build` (or passed as build-args when building the
# Docker image / Portainer stack).
# ─────────────────────────────────────────────────────────────

# HTTP URL of the Hermes API (/v1/chat/completions endpoint).
# In development, point it at the IP of the Raspberry running Hermes.
# If omitted, the app falls back to https://<hostname>:8000.
VITE_HERMES_API_URL=http://192.168.1.xxx:8000

# API key used to authenticate against Hermes (Authorization: Bearer ...).
VITE_HERMES_API_KEY=your-api-key-here

# (Optional / legacy) Hermes WebSocket URL.
# Only used by the useHermesWS hook (the app currently uses HTTP).
# If omitted, defaults to: ws://<hostname>:9119/api/ws
# VITE_HERMES_WS_URL=ws://192.168.1.xxx:9119/api/ws
