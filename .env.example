# ─────────────────────────────────────────────────────────────
# parche-ui + orchestrator — full stack config (`docker compose -f stack.yml`)
# ─────────────────────────────────────────────────────────────

# ── UI (parche-ui) ────────────────────────────────────────────
# nginx reverse-proxies /api/* to the Hermes container, so the browser talks
# same-origin and the API key stays server-side. Usually you only set:

# API key injected by nginx into the Authorization header at runtime.
# (Runtime env — NOT inlined by Vite, NOT shipped to the browser.)
# Also reused by the orchestrator container to call Hermes directly.
HERMES_API_KEY=your-api-key-here

# Hermes bridge for the ask_hermes tool — two modes:
#   http: plain REST /v1/chat/completions. Simple, proven, but no tools/skills.
#   ws:   the gateway WebSocket (tools enabled, same channel as Telegram).
#         Still being debugged (auth/port/path) — switch once confirmed working.
HERMES_MODE=ws
# HERMES_WS_URL=ws://192.168.1.xxx:9119/api/ws
HERMES_WS_TOKEN=parche-internal-dev

# Host port to publish the UI on (container listens on 80).
HOST_PORT=8080

# API base URL baked into the bundle. Defaults to /api (same-origin proxy);
# only change it if you are NOT using the nginx proxy.
# VITE_HERMES_API_URL=/api

# Status updates ({"status": "idle"|"listening"|"thinking"|"talking"}) come
# same-origin by default: nginx proxies /ws-status to the orchestrator
# container over the internal docker network (see nginx.conf), so you normally
# never set this. Only needed if you're bypassing that proxy entirely (e.g.
# pointing the UI at an orchestrator running somewhere else).
# VITE_ORCHESTRATOR_WS_URL=ws://192.168.1.xxx:8765

# ── Orchestrator (voice: Realtime API + Hermes bridge) ───────────────────────
# Branch feature/openai-realtime — see orchestrator/.env.example for the full
# list. These are the ones docker compose actually reads from here.

# Auth for the OpenAI Realtime API (speech-to-speech — replaces the old
# separate Whisper STT + TTS calls entirely).
OPENAI_API_KEY=sk-your-key-here

# REALTIME_MODEL=gpt-realtime
# REALTIME_VOICE=marin

# Left unset, resolves to the ALSA "default" PCM, which orchestrator/asound.conf
# routes to this Pi's actual mic/speaker hardware (see that file to update the
# card/device numbers if you swap hardware).
# MIC_DEVICE=
# SPEAKER_DEVICE=

# No acoustic echo cancellation on this hardware — without an isolated mic,
# the server VAD can pick up Parche's own voice from the speaker. First line
# of defense: raise this so quiet echo bleed-through doesn't count as speech
# while actual close-mic talking still does (0-1, API default ~0.5).
VAD_THRESHOLD=0.7

# Fallback only, off by default since it kills barge-in: mutes the mic
# entirely while Parche talks instead of relying on VAD_THRESHOLD.
# MIC_MUTE_WHILE_SPEAKING=false

# Wake word — on by default, using openWakeWord's bundled pretrained
# "hey_jarvis" model (no training needed). Set OWW_MODEL_PATH to a custom
# model's filename to use a different phrase instead (see WAKE_WORD_MODELS_DIR
# below for where to put it).
# WAKE_WORD_ENABLED=true
# OWW_MODEL_PATH=/app/models/your_model.onnx
# OWW_THRESHOLD=0.5

# Where custom wake-word .onnx files live on the Pi's host filesystem, mounted
# into the orchestrator container at /app/models. Defaults to
# ./orchestrator/models (inside this repo checkout) — but the deploy workflow
# runs `git clean` (which removes gitignored files too) on every push, so a
# custom model dropped there will vanish on the next deploy. Point this at a
# path OUTSIDE the repo instead, e.g. after `mkdir -p ~/parche-models`:
# WAKE_WORD_MODELS_DIR=/home/pi/parche-models

# ── Local development (npm run dev) ──────────────────────────
# There is no nginx proxy in `vite dev`, so point straight at Hermes.
# IMPORTANT: Vite inlines VITE_* at BUILD time.
# VITE_HERMES_API_URL=http://192.168.1.xxx:8000
