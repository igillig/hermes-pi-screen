# ─────────────────────────────────────────────────────────────
# HERMES voice orchestrator config reference — branch feature/openai-realtime.
#
# In production this runs as the `orchestrator` service in ../stack.yml, which
# reads these same values from the repo-root .env (see ../.env.example) —
# that's the one docker compose actually uses.
#
# Copy this file to `.env` here only if you're running main.py directly
# (outside Docker) for local development/debugging with a real mic attached.
# ─────────────────────────────────────────────────────────────

# Auth for the OpenAI Realtime API (speech-to-speech — replaces the old
# separate Whisper STT + TTS calls entirely).
OPENAI_API_KEY=sk-your-key-here

# Realtime API model/voice. Check platform.openai.com/docs/guides/realtime if
# either gets rejected — naming has shifted before.
# REALTIME_MODEL=gpt-realtime
# REALTIME_VOICE=marin

# Override the default Spanish/Argentine persona + filler-phrase-before-tool-call
# instructions baked into main.py (DEFAULT_INSTRUCTIONS). Only set this if you
# want to fully replace them, not tweak — there's no partial-override mechanism.
# REALTIME_INSTRUCTIONS=...

# Hermes bridge for the ask_hermes tool — two modes:
#   http: plain REST /v1/chat/completions. Simple, proven, but no tools/skills
#         (can't actually turn anything on, just answers as a bare LLM).
#   ws:   the gateway WebSocket (same channel Telegram uses, tools enabled).
#         Still being debugged (auth/port/path) — switch once confirmed working.
HERMES_MODE=ws

# Inside the `orchestrator` container this defaults to http://hermes_agent:8000
# (same docker network, no proxy needed). Only set explicitly for local/outside-
# Docker runs, e.g.:
# HERMES_API_URL=http://192.168.1.xxx:8000
HERMES_API_KEY=your-api-key-here

# Gateway WS connection details (HERMES_MODE=ws). Defaults to the same host as
# HERMES_API_URL, port 9119, path /api/ws.
# HERMES_WS_URL=ws://192.168.1.xxx:9119/api/ws
HERMES_WS_TOKEN=parche-internal-dev

# Status WebSocket the UI (Docker, same Pi) connects to.
STATUS_WS_HOST=0.0.0.0
STATUS_WS_PORT=8765

# Optional: pick specific audio devices (see `python -m sounddevice`). Left
# unset, this resolves to the ALSA "default" PCM, which asound.conf routes to
# this Pi's actual mic/speaker hardware.
# MIC_DEVICE=
# SPEAKER_DEVICE=

# No acoustic echo cancellation on this hardware — without an isolated mic,
# the server VAD can pick up Parche's own voice from the speaker. First line
# of defense: raise this so quiet echo bleed-through doesn't count as speech
# while actual close-mic talking still does (0-1, API default ~0.5).
VAD_THRESHOLD=0.7

# Fallback only, off by default since it kills barge-in: mutes the mic
# entirely while Parche is talking (+ a grace period after) instead of
# relying on VAD_THRESHOLD. Only turn on if that alone isn't enough.
# MIC_MUTE_WHILE_SPEAKING=false
# MIC_UNMUTE_DELAY_S=0.4

# ── Wake word via openWakeWord ───────────────────────────────────────────────
# Enabled by default, using openWakeWord's bundled pretrained "hey_jarvis"
# model — no training/account needed, downloaded automatically on first run
# via download_wakeword_models(). Say "hey jarvis" to open the realtime
# connection (this only gates the FIRST connection — see main.py).
WAKE_WORD_ENABLED=true
#
# To use a different phrase instead, train a small custom classifier:
# 1. Open the official training notebook in Google Colab:
#    https://github.com/dscripka/openWakeWord/blob/main/notebooks/automatic_model_training.ipynb
# 2. Set target_word to your phrase (the notebook synthesizes training clips
#    with TTS across many voices/accents, then augments them with noise/reverb
#    — no need to record your own samples).
# 3. Run all cells, download the resulting .onnx, and copy it to the Pi.
# OWW_MODEL_PATH=/path/to/custom_model.onnx
# Detection score threshold 0-1, higher = fewer false triggers but more misses.
OWW_THRESHOLD=0.5
