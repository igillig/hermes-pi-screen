# ─────────────────────────────────────────────────────────────
# HERMES voice orchestrator config reference.
#
# In production this runs as the `orchestrator` service in ../stack.yml, which
# reads these same values from the repo-root .env (see ../.env.example) —
# that's the one docker compose actually uses.
#
# Copy this file to `.env` here only if you're running main.py directly
# (outside Docker) for local development/debugging with a real mic attached.
# ─────────────────────────────────────────────────────────────

OPENAI_API_KEY=sk-your-key-here

# Hermes chat-completions endpoint. Inside the `orchestrator` container this
# defaults to http://hermes_agent:8000 (same docker network, no proxy needed).
# Only set this explicitly for local/outside-Docker runs, e.g.:
# HERMES_API_URL=http://192.168.1.xxx:8000
HERMES_API_KEY=your-api-key-here

# Status WebSocket the UI (Docker, same Pi) connects to.
STATUS_WS_HOST=0.0.0.0
STATUS_WS_PORT=8765

STT_LANGUAGE=es
TTS_MODEL=tts-1-hd
TTS_VOICE=nova

# Optional: pick specific audio devices (see `python -m sounddevice`).
# MIC_DEVICE=
# SPEAKER_DEVICE=

# VAD tuning (0-3, higher = more aggressive filtering of non-speech).
VAD_AGGRESSIVENESS=2

# ── Wake word ("che parche") via openWakeWord ────────────────────────────────
# Disabled for now — the mic just listens permanently (VAD-only, no gate) until
# the pipeline is validated end to end. Flip WAKE_WORD_ENABLED=true once the
# custom model below is trained and ready.
WAKE_WORD_ENABLED=false
#
# No account/approval needed (fully open source), but "che parche" isn't a
# built-in keyword — you train a small custom classifier once:
#
# 1. Open the official training notebook in Google Colab:
#    https://github.com/dscripka/openWakeWord/blob/main/notebooks/automatic_model_training.ipynb
# 2. Set target_word = "che parche" (the notebook synthesizes training clips
#    with TTS across many voices/accents, then augments them with noise/reverb
#    — no need to record your own samples).
# 3. Run all cells. It trains a small ONNX classifier on top of openWakeWord's
#    shared feature-extraction models (those are downloaded automatically by
#    this script on first run via `download_wakeword_models()` — separate from
#    the custom model you're training).
# 4. Download the resulting `che_parche.onnx` from Colab and copy it to the Pi.
# Required only when WAKE_WORD_ENABLED=true.
# OWW_MODEL_PATH=/path/to/che_parche.onnx
# Detection score threshold 0-1, higher = fewer false triggers but more misses.
OWW_THRESHOLD=0.5
